[Unit]
Description=soos-lights DMX controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=soos
Group=soos
WorkingDirectory=/opt/soos-lights
Environment="PATH=/opt/soos-lights/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="HOME=/opt/soos-lights"
# DMX_PORT can be overridden here if auto-detection picks the wrong device:
#   Environment="DMX_PORT=/dev/serial/by-id/usb-FTDI_FT232R_USB_UART_BG03CYC2-if00-port0"

ExecStart=/opt/soos-lights/.local/bin/uv run python app.py
Restart=on-failure
RestartSec=5
TimeoutStopSec=10

# Light hardening — ProtectSystem=full makes /usr, /boot, /efi read-only
# but leaves the service free to write anywhere under its own home
# (state/, patterns.json, uv cache, npm cache, build artifacts).
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=no
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
